			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'linked_sarath_AzureDataLakeStorage2'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adls123456.dfs.core.windows.net/"
